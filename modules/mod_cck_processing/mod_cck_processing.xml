<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" version="2.5" method="upgrade">
	<name>mod_cck_processing</name>
	<author>Octopoos</author>
	<authorEmail>contact@seblod.com</authorEmail>
	<authorUrl>https://www.seblod.com</authorUrl>
	<copyright>Copyright (C) 2009 - 2018 SEBLOD. All Rights Reserved.</copyright>
	<license>GNU General Public License version 2 or later.</license>
	<creationDate>June 2014</creationDate>
	<description>LIB_CCK_EXTENSION_DESCRIPTION</description>
	<version>6.0.3</version>
	
	<files>
		<folder>tmpl</folder>
		
		<filename module="mod_cck_processing">mod_cck_processing.php</filename>
		<filename>index.html</filename>
	</files>
	
	<languages folder="languages">
			<language tag="en-GB">en-GB/en-GB.mod_cck_processing.ini</language>
			<language tag="en-GB">en-GB/en-GB.mod_cck_processing.sys.ini</language>
			<language tag="fr-FR">fr-FR/fr-FR.mod_cck_processing.ini</language>
			<language tag="fr-FR">fr-FR/fr-FR.mod_cck_processing.sys.ini</language>
	</languages>
	
	<config>
		<fields name="params" addfieldpath="/libraries/cck/construction/field">
			<fieldset name="basic">
				<field name="processing" type="sql" default="" label="MOD_CCK_PROCESSING_ID" description="MOD_CCK_PROCESSING_ID_DESC" query="SELECT id, title FROM #__cck_more_processings WHERE published=1 AND type=0 ORDER BY title" key_field="id" value_field="title" class="inputbox" required="true">
					<option value="">JGLOBAL_SELECT_AN_OPTION</option>
				</field>
			</fieldset>
			<fieldset name="cck-url" label="LIB_CCK_FIELDSET_URL_ASSIGNMENT">
				<field name="url_show" type="text" label="MOD_CCK_PROCESSING_CONFIG_URL_SHOW" description="MOD_CCK_PROCESSING_CONFIG_URL_SHOW_DESC" class="inputbox" size="50" />
				<field name="url_hide" type="text" label="MOD_CCK_PROCESSING_CONFIG_URL_HIDE" description="MOD_CCK_PROCESSING_CONFIG_URL_HIDE_DESC" class="inputbox" size="50" />
			</fieldset>	
			<fieldset name="advanced">
				<field name="layout" type="modulelayout" label="JFIELD_ALT_LAYOUT_LABEL" description="JFIELD_ALT_MODULE_LAYOUT_DESC" class="inputbox" />
				<field name="moduleclass_sfx" type="textarea" rows="3" label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL" description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC" class="inputbox" />
				<field name="force_moduleclass_sfx" type="list" label="LIB_CCK_MODULES_FORCE_MODULECLASS_SFX" default="0" description="LIB_CCK_MODULES_FORCE_MODULECLASS_SFX_DESC" class="inputbox">
					<option value="0">JNO</option>
					<option	value="1">JYES</option>
				</field>
				<field name="raw_rendering" type="list" label="LIB_CCK_RAW_RENDERING" default="" description="LIB_CCK_RAW_RENDERING_DESC" class="inputbox">
					<option value="">COM_CCK_INHERITED_SL</option>
					<option value="0">JNO</option>
					<option	value="1">JYES</option>
				</field>
				<field name="" type="spacer" label="" />
				<field name="" type="spacer" label="" />
			</fieldset>
		</fields>
	</config>
</extension>